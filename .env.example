# ── Required ──────────────────────────────────────────────────────────────────
# JWT signing secret — minimum 32 characters, keep this private!
JWT_SECRET=change-me-to-a-long-random-secret-string-here

# ── Optional ──────────────────────────────────────────────────────────────────
# Path on the HOST to your snapshot images folder (mounted RO into the container)
SNAPSHOTS_PATH=./snapshots

# Exposed port (default: 3000)
PORT=3000

# Allowed CORS origin (default: http://localhost:3000)
CORS_ORIGIN=http://localhost:3000

# Max file size for API uploads in MB (default: 50)
MAX_UPLOAD_SIZE_MB=50

# ── Local development only (not used by Docker) ───────────────────────────────
# Override these when running the backend directly (npm run dev)
# DB_PATH=./dev.db
# IMAGE_ADMIN_PATH=../sample-images
# IMAGE_UPLOADS_PATH=./uploads
